generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum RunStatus {
  draft
  awaiting_mapping
  ready_to_process
  processing
  review_required
  completed
  exported
  failed
}

enum FileKind {
  transaction_file
  document
  archive
  derived_image
  export_file
}

enum MatchStatus {
  matched
  probable_match
  multiple_candidates
  unmatched
  duplicate_suspected
}

enum ReviewActionType {
  approve
  edit_field
  rematch
  override_vat_code
  override_gl_code
  no_receipt_required
  exclude_from_export
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  void
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String
  passwordHash    String
  accountType     String          @default("business_user")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  memberships     Membership[]
  reviewActions   ReviewAction[]
  exportHistories ExportHistory[]
  invitations     Invitation[]    @relation("InvitedBy")
  transactionComments TransactionComment[]
  reviewSubmissionsSubmitted ReviewSubmission[] @relation("ReviewSubmissionSubmitter")
  reviewSubmissionsReviewed  ReviewSubmission[] @relation("ReviewSubmissionReviewer")
}

model Workspace {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  defaultCurrency   String              @default("GBP")
  countryProfile    String              @default("GB")
  amountTolerance   Decimal             @db.Decimal(10, 2)
  dateToleranceDays Int                 @default(5)
  vatRegistered     Boolean             @default(false)
  businessType      String              @default("sole_trader")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  memberships       Membership[]
  runs              ReconciliationRun[]
  vatRules          VatRule[]
  glCodeRules       GlCodeRule[]
  categoryRules     CategoryRule[]
  mappingTemplates  MappingTemplate[]
  bankStatements    BankStatement[]
  invitations       Invitation[]
  clients           Client[]
  invoices          Invoice[]
  manualExpenses    ManualExpense[]
  categoryBudgets   CategoryBudget[]
  transactionComments TransactionComment[]
  reviewSubmissions ReviewSubmission[]
}

model Membership {
  id          String    @id @default(cuid())
  role        String    @default("owner")
  createdAt   DateTime  @default(now())
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model ReconciliationRun {
  id                  String          @id @default(cuid())
  name                String
  status              RunStatus       @default(draft)
  entity              String?
  period              String?
  locked              Boolean         @default(false)
  lockedAt            DateTime?
  lockedBy            String?
  countryProfile      String?
  bankStatementId     String?
  bankSourceMode      String?
  bankSourceLabel     String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  processedAt         DateTime?
  workspaceId         String
  transactionFileName String?
  notes               String?
  fxRates             Json?
  workspace           Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bankStatement       BankStatement?  @relation(fields: [bankStatementId], references: [id], onDelete: SetNull)
  uploadedFiles       UploadedFile[]
  transactions        Transaction[]
  documents           Document[]
  matches             MatchDecision[]
  reviewActions       ReviewAction[]
  exports             ExportHistory[]

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, status])
  @@index([bankStatementId])
}

model BankStatement {
  id                  String              @id @default(cuid())
  name                String
  fileName            String
  bankName            String?
  accountName         String?
  currency            String              @default("GBP")
  importedAt          DateTime            @default(now())
  importStatus        String              @default("imported")
  dateRangeStart      DateTime?
  dateRangeEnd        DateTime?
  previewHeaders      Json?
  savedColumnMappings Json?
  workspaceId         String
  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions        BankTransaction[]
  runs                ReconciliationRun[]

  @@index([workspaceId, importedAt(sort: Desc)])
}

model BankTransaction {
  id                 String        @id @default(cuid())
  externalId         String?
  sourceLineNumber   Int?
  transactionDate    DateTime?
  postedDate         DateTime?
  amount             Decimal       @db.Decimal(12, 2)
  currency           String?
  merchant           String?
  description        String?
  employee           String?
  reference          String?
  bankStatementId    String
  bankStatement      BankStatement @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)
  vatCode            String?
  glCode             String?
  category           String?
  taxTreatment       String?
  taxRate            Decimal?      @db.Decimal(5, 2)
  noReceiptRequired  Boolean       @default(false)
  isClaimableOverride Boolean?
  excludedFromExport Boolean       @default(false)
  categoryConfidence String?
  categoryReason     String?
  confidenceScore    Decimal?      @db.Decimal(4, 2)
  runTransactions    Transaction[]

  @@index([bankStatementId, transactionDate])
  @@index([bankStatementId, postedDate])
  @@index([merchant])
  @@index([amount])
}

model UploadedFile {
  id           String            @id @default(cuid())
  fileName     String
  originalName String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  fileKind     FileKind
  createdAt    DateTime          @default(now())
  runId        String
  run          ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                      String            @id @default(cuid())
  sourceBankTransactionId String?
  externalId              String?
  sourceLineNumber        Int?
  transactionDate         DateTime?
  postedDate              DateTime?
  amount                  Decimal           @db.Decimal(12, 2)
  currency                String?
  merchant                String?
  description             String?
  employee                String?
  reference               String?
  vatCode                 String?
  glCode                  String?
  category                String?
  taxTreatment            String?
  taxRate                 Decimal?          @db.Decimal(5, 2)
  noReceiptRequired       Boolean           @default(false)
  isClaimableOverride     Boolean?
  excludedFromExport      Boolean           @default(false)
  categoryConfidence      String?
  categoryReason          String?
  confidenceScore         Decimal?          @db.Decimal(4, 2)
  runId                   String
  run                     ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sourceBankTransaction   BankTransaction?  @relation(fields: [sourceBankTransactionId], references: [id], onDelete: SetNull)
  matches                 MatchDecision[]

  @@index([runId, transactionDate])
  @@index([runId, postedDate])
  @@index([sourceBankTransactionId])
  @@index([merchant])
  @@index([amount])
}

model Document {
  id                   String            @id @default(cuid())
  fileName             String
  supplier             String?
  issueDate            DateTime?
  gross                Decimal?          @db.Decimal(12, 2)
  net                  Decimal?          @db.Decimal(12, 2)
  vat                  Decimal?          @db.Decimal(12, 2)
  vatRateSummary       String?
  documentNumber       String?
  countryCode          String?
  currency             String?
  rawExtractedText     String?
  extractionConfidence Decimal?          @db.Decimal(4, 2)
  duplicateFingerprint String?
  runId                String
  run                  ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  taxLines             DocumentTaxLine[]
  matches              MatchDecision[]

  @@index([runId, issueDate])
  @@index([supplier])
  @@index([gross])
}

model DocumentTaxLine {
  id          String   @id @default(cuid())
  label       String?
  netAmount   Decimal? @db.Decimal(12, 2)
  taxAmount   Decimal? @db.Decimal(12, 2)
  grossAmount Decimal? @db.Decimal(12, 2)
  rate        Decimal? @db.Decimal(5, 2)
  recoverable Boolean  @default(true)
  vatCode     String?
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model MatchDecision {
  id            String            @id @default(cuid())
  status        MatchStatus
  score         Decimal           @db.Decimal(5, 2)
  rationale     Json
  selected      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  transactionId String
  documentId    String?
  runId         String
  transaction   Transaction       @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  document      Document?         @relation(fields: [documentId], references: [id], onDelete: SetNull)
  run           ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, transactionId])
  @@index([documentId])
}

model ReviewAction {
  id            String            @id @default(cuid())
  actionType    ReviewActionType
  field         String?
  beforeValue   String?
  afterValue    String?
  note          String?
  createdAt     DateTime          @default(now())
  runId         String
  transactionId String?
  documentId    String?
  actorId       String
  run           ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  actor         User              @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt(sort: Desc)])
}

model TransactionComment {
  id            String    @id @default(cuid())
  transactionId String
  transactionSource String @default("transaction")
  body          String
  requestType   String?   // missing_receipt | personal_check | vat_check | category_check | general
  resolved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspaceId   String
  authorId      String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([workspaceId, transactionId, createdAt(sort: Desc)])
  @@index([authorId])
}

model ReviewSubmission {
  id             String    @id @default(cuid())
  status         String    @default("submitted") // submitted | in_review | changes_requested | reviewed
  period         String?
  note           String?
  readinessJson  Json?
  submittedAt    DateTime  @default(now())
  reviewedAt     DateTime?
  workspaceId    String
  submittedById  String
  reviewedById   String?
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submittedBy    User      @relation("ReviewSubmissionSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  reviewedBy     User?     @relation("ReviewSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, submittedAt(sort: Desc)])
  @@index([status])
}

model VatRule {
  id          String    @id @default(cuid())
  countryCode String
  rate        Decimal   @db.Decimal(5, 2)
  taxCode     String
  recoverable Boolean   @default(true)
  description String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, taxCode])
  @@index([workspaceId, countryCode])
}

model GlCodeRule {
  id              String    @id @default(cuid())
  glCode          String
  label           String
  supplierPattern String?
  keywordPattern  String?
  priority        Int       @default(100)
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, priority])
}

model CategoryRule {
  id                    String    @id @default(cuid())
  category              String
  slug                  String
  description           String?
  section               String    @default("Other & Special")
  supplierPattern       String?
  keywordPattern        String?
  priority              Int       @default(100)
  accountType           String    @default("expense")
  statementType         String    @default("p_and_l")
  reportingBucket       String    @default("Other Expenses")
  defaultTaxTreatment   String    @default("standard_rated")
  defaultVatRate        Decimal   @default(20) @db.Decimal(5, 2)
  defaultVatRecoverable Boolean   @default(true)
  glCode                String?
  isSystemDefault       Boolean   @default(true)
  isActive              Boolean   @default(true)
  isVisible             Boolean   @default(true)
  allowableForTax       Boolean   @default(true)
  allowablePercentage   Decimal   @default(100) @db.Decimal(5, 2)
  sortOrder             Int       @default(1000)
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId, priority])
  @@index([workspaceId, section, sortOrder])
}

model MappingTemplate {
  id             String    @id @default(cuid())
  name           String
  sourceType     String
  columnMappings Json
  createdAt      DateTime  @default(now())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model ExportHistory {
  id        String            @id @default(cuid())
  format    String
  fileName  String
  createdAt DateTime          @default(now())
  runId     String
  actorId   String
  run       ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  actor     User              @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt(sort: Desc)])
}

model Invitation {
  id          String           @id @default(cuid())
  email       String
  role        String           @default("viewer")
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  workspaceId String
  invitedById String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([workspaceId])
  @@index([email])
}

// ─── Sole Trader Features ─────────────────────────────────────────────────────

model Client {
  id               String    @id @default(cuid())
  name             String
  email            String?
  phone            String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  postcode         String?
  country          String?
  vatNumber        String?
  paymentTermsDays Int       @default(30)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices         Invoice[]

  @@index([workspaceId, name])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String
  status        InvoiceStatus @default(draft)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  lineItems     Json          // InvoiceLineItem[]
  subtotal      Decimal       @db.Decimal(12, 2)
  vatAmount     Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  currency      String        @default("GBP")
  notes         String?
  paidAt        DateTime?
  paidAmount    Decimal?      @db.Decimal(12, 2)
  clientId      String
  workspaceId   String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([workspaceId, status])
  @@index([workspaceId, issueDate(sort: Desc)])
  @@index([clientId])
}

model ManualExpense {
  id                String    @id @default(cuid())
  date              DateTime
  description       String
  merchant          String?
  category          String?
  vatCode           String?
  glCode            String?
  amount            Decimal   @db.Decimal(12, 2)
  currency          String    @default("GBP")
  isMileage         Boolean   @default(false)
  mileageMiles      Decimal?  @db.Decimal(10, 2)
  mileageRatePerMile Decimal? @db.Decimal(6, 4)
  receiptStorageKey String?
  notes             String?
  isClaimableOverride Boolean?
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())

  @@index([workspaceId, date(sort: Desc)])
  @@index([workspaceId, category])
}

model CategoryBudget {
  id          String    @id @default(cuid())
  category    String
  amount      Decimal   @db.Decimal(12, 2)
  period      String    @default("monthly") // monthly | annual
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, category])
  @@index([workspaceId])
}
